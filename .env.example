# ============================================================
# SecureBank Slack-Clone — .env.example
# Copy to .env and fill in real values. NEVER commit .env.
# ============================================================

# --- Django Core ---
SECRET_KEY=CHANGE_ME_USE_DJANGO_SECRET_KEY_GEN_50_CHARS
DEBUG=False
ALLOWED_HOSTS=yourdomain.com,localhost

# --- Database (PostgreSQL) ---
DB_ENGINE=django.db.backends.postgresql
DB_NAME=securebank_slack
DB_USER=sbslack_admin
DB_PASSWORD=STRONG_PASSWORD_HERE
DB_HOST=localhost
DB_PORT=5432

# --- Redis (Channels + Celery) ---
REDIS_URL=redis://localhost:6379/0
CELERY_BROKER_URL=redis://localhost:6379/1

# --- JWT ---
JWT_ACCESS_TOKEN_LIFETIME_MINUTES=15
JWT_REFRESH_TOKEN_LIFETIME_DAYS=1
JWT_SIGNING_KEY=CHANGE_ME_SEPARATE_FROM_SECRET_KEY

# --- Encryption Master Keys ---
# AES-256-GCM master key (32 bytes, hex-encoded)
AES_MASTER_KEY=CHANGE_ME_64_HEX_CHARS_AES256
# PQC Kyber-1024 server private key path
PQC_KYBER_PRIVATE_KEY_PATH=/secrets/kyber_private.key
# PQC Dilithium3 signing key path
PQC_DILITHIUM_PRIVATE_KEY_PATH=/secrets/dilithium_private.key

# --- IPFS ---
IPFS_API_URL=http://127.0.0.1:5001
IPFS_GATEWAY=https://ipfs.io/ipfs/

# --- Email (MFA OTP delivery) ---
EMAIL_HOST=smtp.yourbank.com
EMAIL_PORT=587
EMAIL_HOST_USER=noreply@yourbank.com
EMAIL_HOST_PASSWORD=SMTP_PASSWORD
EMAIL_USE_TLS=True

# --- OAuth2 (Enterprise SSO) ---
SOCIAL_AUTH_AZUREAD_OAUTH2_KEY=AZURE_APP_CLIENT_ID
SOCIAL_AUTH_AZUREAD_OAUTH2_SECRET=AZURE_APP_SECRET

# --- Sentry ---
SENTRY_DSN=https://your-sentry-dsn@sentry.io/project

# --- USB Hardware Keys (FIDO2/PIV) ---
USB_KEY_VENDOR_ID_1=0x1050
USB_KEY_PRODUCT_ID_1=0x0407
USB_KEY_VENDOR_ID_2=0x096E
USB_KEY_PRODUCT_ID_2=0x0858

# --- Anti-Forensics TTL ---
MESSAGE_DEFAULT_TTL_SECONDS=86400      # 24h default
VAULT_SESSION_TTL_SECONDS=3600         # 1h vault access window
WIPE_SCHEDULE_CRON=0 3 * * *           # 3am daily wipe pass

# --- CORS ---
CORS_ALLOWED_ORIGINS=https://yourdomain.com

# --- HSTS ---
SECURE_HSTS_SECONDS=31536000
